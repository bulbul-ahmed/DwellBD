    "clsx": "^2.0.0",
    "dayjs": "^1.11.8",
    "framer-motion": "^10.12.16",
    "jwt-decode": "^4.0.0",
    "lucide-react": "^0.263.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.45.2",
    "react-hot-toast": "^2.4.1",
    "react-image-gallery": "^1.2.11",
    "react-intersection-observer": "^9.5.1",
