export async function updateUserHandler(req: Request, res: Response): Promise<void> {
  try {
    const { id } = req.params
    const updateData = req.body
    const result = await updateUserByAdmin(id, updateData)
    res.json(result)
  } catch (error) {
    console.error('Error updating user:', error)
    res.status(500).json({ error: 'Failed to update user' })
  }
}

export async function getAnalyticsDataHandler(req: Request, res: Response): Promise<void> {
  try {
    const {
      userGrowthDays = 30,
      topPropertiesLimit = 10,
      recentActivityLimit = 10
    } = req.query

    const [
      overview,
      userGrowth,
      propertyTypeDist,
      propertyStatusDist,
      topProperties,
      recentActivity
    ] = await Promise.all([
      getOverviewStats(),
      getUserGrowthTrend(Number(userGrowthDays)),
      getPropertyTypeDistribution(),
      getPropertyStatusDistribution(),
      getTopPerformingProperties(Number(topPropertiesLimit)),
      getRecentActivity(Number(recentActivityLimit))
    ])

    res.json({
      overview,
      userGrowth,
      propertyTypeDistribution: propertyTypeDist,
      propertyStatusDistribution: propertyStatusDist,
      topProperties,
      recentActivity
    })
  } catch (error) {
    console.error('Error fetching analytics data:', error)
    res.status(500).json({ error: 'Failed to fetch analytics data' })
  }
}

export async function getMonthlyTrendsHandler(req: Request, res: Response): Promise<void> {
  try {
    const monthlyData = await getMonthlyData()
    res.json(monthlyData)
  } catch (error) {
    console.error('Error fetching monthly trends:', error)
    res.status(500).json({ error: 'Failed to fetch monthly trends' })
  }
}

export async function getPendingApprovalsHandler(req: Request, res: Response): Promise<void> {
  try {
    const { page = 1, limit = 10 } = req.query
    const result = await getPropertiesForAdmin(
      Number(page),
      Number(limit),
      { status: 'PENDING' }
    )
    res.json(result)
  } catch (error) {
    console.error('Error fetching pending approvals:', error)
    res.status(500).json({ error: 'Failed to fetch pending approvals' })
  }
}
