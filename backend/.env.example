# Backend Environment Variables
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL="postgresql://username:password@localhost:5432/bdflat_hub"

# Frontend URL
FRONTEND_URL=http://localhost:3000

# JWT Secrets (Generate with: openssl rand -hex 64)
# IMPORTANT: Use different secrets for each environment! Never commit real secrets!
JWT_SECRET=your_64_character_random_hex_secret_here_generate_with_openssl_rand
JWT_REFRESH_SECRET=your_64_character_refresh_secret_here_different_from_jwt_secret

# AWS S3 (for file uploads)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=bdflathub-prod

# Email Service (for notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-email-password