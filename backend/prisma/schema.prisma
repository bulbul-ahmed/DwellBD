generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  phone       String?
  password    String
  firstName   String
  lastName    String
  role        UserRole @default(TENANT)
  isVerified  Boolean  @default(false)
  isActive   Boolean  @default(true)
  avatar      String?
  failedLoginAttempts Int      @default(0)
  lockedUntil         DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Owner-specific fields
  serviceAreas        String[] @default([])
  businessName        String?  @db.VarChar(100)
  businessLocation    String?  @db.VarChar(200)
  verificationAddress String?  @db.Text // For KYC only, never shown publicly

  // Relations
  properties  Property[]
  favorites   Favorite[]
  reviews     Review[]
  bookings    Booking[]
  passwordResets PasswordReset[]
  inquiries    Inquiry[]
  propertyViews PropertyView[]
  ratingsGiven    UserRating[] @relation("RatingsGiven")
  ratingsReceived UserRating[] @relation("RatingsReceived")
  tenantVisits    VisitRequest[] @relation("TenantVisits")
  ownerVisits     VisitRequest[] @relation("OwnerVisits")
  ownerRequests    OwnerRequest[] @relation("OwnerRequests")
  reviewedRequests OwnerRequest[] @relation("ReviewedRequests")

  @@index([email])
  @@index([role])
  @@index([isVerified])
  @@index([createdAt])
  @@map("users")
}

model Property {
  id          String        @id @default(cuid())
  title       String
  description String?
  type        PropertyType
  listingType ListingType?
  address     String
  area        String
  subArea     String?
  city        String?
  latitude    Float?
  longitude   Float?
  bedrooms    Int?
  bathrooms   Int?
  floorNumber Int?
  totalFloors Int?
  squareFeet  Int?
  furnished   Furnished?
  rentAmount  Float
  rentPeriod  RentPeriod?
  securityDeposit Float?
  advancePayment Float?
  serviceCharge Float?
  amenities   String[]
  availableFrom DateTime?
  coverImage  String?
  images      String[]
  videoUrl    String?
  gasType     GasType?
  tenantPreference TenantPreference?
  status      PropertyStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  owner       User       @relation(fields: [ownerId], references: [id])
  ownerId     String
  favorites   Favorite[]
  reviews     Review[]
  bookings    Booking[]
  inquiries    Inquiry[]
  propertyViews PropertyView[]
  visitRequests VisitRequest[]

  @@index([ownerId])
  @@index([status])
  @@index([area])
  @@index([area, subArea])
  @@index([type])
  @@index([rentAmount])
  @@index([createdAt])
  @@index([area, status])
  @@index([type, status])
  @@map("properties")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  propertyId String
  createdAt DateTime @default(now())

  // Relations
  user      User     @relation(fields: [userId], references: [id])
  property   Property @relation(fields: [propertyId], references: [id])

  @@unique([userId, propertyId])
  @@index([userId])
  @@index([propertyId])
  @@index([createdAt])
  @@map("favorites")
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  propertyId String
  rating    Int      @db.SmallInt
  comment   String?
  createdAt DateTime @default(now())

  // Relations
  user      User     @relation(fields: [userId], references: [id])
  property   Property @relation(fields: [propertyId], references: [id])

  @@index([propertyId])
  @@index([userId])
  @@index([rating])
  @@map("reviews")
}

model Booking {
  id        String        @id @default(cuid())
  userId    String
  propertyId String
  checkIn   DateTime
  checkOut  DateTime
  status    BookingStatus @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  // Relations
  user      User     @relation(fields: [userId], references: [id])
  property   Property @relation(fields: [propertyId], references: [id])
  ratings   UserRating[]

  @@index([userId])
  @@index([propertyId])
  @@index([status])
  @@map("bookings")
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  // Relations
  user      User     @relation(fields: [userId], references: [id])

  @@map("password_resets")
}

enum UserRole {
  TENANT
  OWNER
  ADMIN
}

enum PropertyType {
  BACHELOR
  FAMILY
  HOSTEL
  SUBLET
  OFFICE
}

enum ListingType {
  RENT
  SELL
}

enum Furnished {
  NONE
  PARTIAL
  FULL
}

enum RentPeriod {
  MONTHLY
  YEARLY
}

enum GasType {
  NATURAL_GAS
  LP_GAS
  CYLINDER
}

enum TenantPreference {
  FAMILY
  BACHELOR
  OFFICE
  ANY
}

enum PropertyStatus {
  PENDING
  PENDING_APPROVAL      // Awaiting admin approval for new properties
  ACTIVE
  INACTIVE
  RENTED
  SOLD
  UNDER_DISCUSSION
  BOOKED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

// Missing models referenced in services
model Inquiry {
  id          String   @id @default(cuid())
  userId      String?
  propertyId  String
  name        String
  email       String
  phone       String
  message     String?
  status      InquiryStatus @default(PENDING)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user      User?     @relation(fields: [userId], references: [id])
  property   Property @relation(fields: [propertyId], references: [id])

  @@index([propertyId])
  @@index([status])
  @@map("inquiries")
}

model PropertyView {
  id          String   @id @default(cuid())
  userId      String?
  propertyId  String
  viewedAt    DateTime @default(now())

  // Relations
  user      User?     @relation(fields: [userId], references: [id])
  property   Property @relation(fields: [propertyId], references: [id])

  @@unique([userId, propertyId])
  @@index([propertyId])
  @@index([viewedAt])
  @@map("property_views")
}

model UserRating {
  id            String   @id @default(cuid())

  // Who gave the rating
  fromUserId    String
  fromUser      User     @relation("RatingsGiven", fields: [fromUserId], references: [id], onDelete: Cascade)

  // Who received the rating
  toUserId      String
  toUser        User     @relation("RatingsReceived", fields: [toUserId], references: [id], onDelete: Cascade)

  // Rating details
  rating        Int      @db.SmallInt // 1-5 stars
  review        String?  // Optional review text
  ratingType    RatingType // OWNER or TENANT

  // Optional: Link to booking
  bookingId     String?
  booking       Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  // Timestamps
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Unique constraint: one rating per user pair per booking
  @@unique([fromUserId, toUserId, bookingId])
  @@index([toUserId])
  @@index([fromUserId])

  @@map("user_ratings")
}

model VisitRequest {
  id              String        @id @default(cuid())

  // Property and users
  propertyId      String
  property        Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  tenantId        String
  tenant          User          @relation("TenantVisits", fields: [tenantId], references: [id], onDelete: Cascade)

  ownerId         String
  owner           User          @relation("OwnerVisits", fields: [ownerId], references: [id], onDelete: Cascade)

  // Visit scheduling
  requestedDate   DateTime      // Initial date requested by tenant
  requestedTime   String        // Time in HH:mm format (e.g., "14:30")

  confirmedDate   DateTime?     // Final confirmed date (set by owner)
  confirmedTime   String?       // Final confirmed time

  suggestedDate   DateTime?     // Alternative date suggested by owner
  suggestedTime   String?       // Alternative time suggested by owner

  // Messages
  tenantNote      String?       @db.Text
  ownerNote       String?       @db.Text
  rejectionReason String?       @db.Text

  // Status tracking
  status          VisitStatus   @default(PENDING)

  // Timestamps
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  completedAt     DateTime?     // When marked as completed

  @@index([propertyId])
  @@index([tenantId])
  @@index([ownerId])
  @@index([status])
  @@index([requestedDate])
  @@index([confirmedDate])
  @@map("visit_requests")
}

model OwnerRequest {
  id              String        @id @default(cuid())

  // Owner who submitted the request
  userId          String
  user            User          @relation("OwnerRequests", fields: [userId], references: [id], onDelete: Cascade)

  // Request details
  requestType     RequestType
  status          RequestStatus @default(PENDING)

  // Request data (stores the requested changes as JSON)
  requestData     Json          // New values being requested
  currentData     Json?         // Current values (for comparison)
  reason          String        @db.Text // Why the change is needed

  // Admin review
  reviewedBy      String?
  reviewer        User?         @relation("ReviewedRequests", fields: [reviewedBy], references: [id], onDelete: SetNull)
  reviewNotes     String?       @db.Text
  rejectionReason String?       @db.Text

  // Timestamps
  createdAt       DateTime      @default(now())
  reviewedAt      DateTime?
  updatedAt       DateTime      @updatedAt

  @@index([userId, status])
  @@index([status, createdAt])
  @@index([requestType])
  @@map("owner_requests")
}

enum RequestType {
  BUSINESS_INFO_CHANGE      // Change business name/location
  SERVICE_AREA_CHANGE       // Add/remove service areas
  PROPERTY_APPROVAL         // New property needs approval
  PROPERTY_EDIT_APPROVAL    // Major property edits
  VERIFICATION_REQUEST      // Request business verification
  CONTACT_INFO_CHANGE       // Change phone/email (sensitive)
}

enum RequestStatus {
  PENDING       // Awaiting admin review
  IN_REVIEW     // Admin is reviewing
  APPROVED      // Admin approved, changes applied
  REJECTED      // Admin rejected the request
  CANCELLED     // Owner cancelled the request
}

enum RatingType {
  OWNER
  TENANT
}

enum VisitStatus {
  PENDING             // Initial state - awaiting owner response
  CONFIRMED           // Owner confirmed the visit
  PENDING_ALTERNATIVE // Owner suggested alternative date
  REJECTED            // Owner declined the request
  CANCELLED           // Tenant cancelled before confirmation
  COMPLETED           // Visit happened (marked after date passed)
}

enum InquiryStatus {
  PENDING
  RESPONDED
  CLOSED
}
