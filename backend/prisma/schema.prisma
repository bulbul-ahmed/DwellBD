generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  phone       String?
  password    String
  firstName   String
  lastName    String
  role        UserRole @default(TENANT)
  isVerified  Boolean  @default(false)
  isActive   Boolean  @default(true)
  avatar      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  properties  Property[]
  favorites   Favorite[]
  reviews     Review[]
  bookings    Booking[]
  passwordResets PasswordReset[]
  inquiries    Inquiry[]
  propertyViews PropertyView[]
  ratingsGiven    UserRating[] @relation("RatingsGiven")
  ratingsReceived UserRating[] @relation("RatingsReceived")

  @@map("users")
}

model Property {
  id          String        @id @default(cuid())
  title       String
  description String?
  type        PropertyType
  listingType ListingType?
  address     String
  area        String
  city        String?
  latitude    Float?
  longitude   Float?
  bedrooms    Int?
  bathrooms   Int?
  floorNumber Int?
  totalFloors Int?
  squareFeet  Int?
  furnished   Furnished?
  rentAmount  Float
  rentPeriod  RentPeriod?
  securityDeposit Float?
  advancePayment Float?
  amenities   String[]
  availableFrom DateTime?
  coverImage  String?
  images      String[]
  videoUrl    String?
  status      PropertyStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  owner       User       @relation(fields: [ownerId], references: [id])
  ownerId     String
  favorites   Favorite[]
  reviews     Review[]
  bookings    Booking[]

    inquiries    Inquiry[]
  propertyViews PropertyView[]

  @@map("properties")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  propertyId String
  createdAt DateTime @default(now())

  // Relations
  user      User     @relation(fields: [userId], references: [id])
  property   Property @relation(fields: [propertyId], references: [id])

  @@unique([userId, propertyId])
  @@map("favorites")
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  propertyId String
  rating    Int      @db.SmallInt
  comment   String?
  createdAt DateTime @default(now())

  // Relations
  user      User     @relation(fields: [userId], references: [id])
  property   Property @relation(fields: [propertyId], references: [id])

  @@map("reviews")
}

model Booking {
  id        String        @id @default(cuid())
  userId    String
  propertyId String
  checkIn   DateTime
  checkOut  DateTime
  status    BookingStatus @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  // Relations
  user      User     @relation(fields: [userId], references: [id])
  property   Property @relation(fields: [propertyId], references: [id])
  ratings   UserRating[]

  @@map("bookings")
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  // Relations
  user      User     @relation(fields: [userId], references: [id])

  @@map("password_resets")
}

enum UserRole {
  TENANT
  OWNER
  ADMIN
}

enum PropertyType {
  BACHELOR
  FAMILY
  HOSTEL
  SUBLET
  OFFICE
}

enum ListingType {
  RENT
  SELL
}

enum Furnished {
  NONE
  PARTIAL
  FULL
}

enum RentPeriod {
  MONTHLY
  YEARLY
}

enum PropertyStatus {
  PENDING
  ACTIVE
  INACTIVE
  RENTED
  SOLD
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

// Missing models referenced in services
model Inquiry {
  id          String   @id @default(cuid())
  userId      String?
  propertyId  String
  name        String
  email       String
  phone       String
  message     String?
  status      InquiryStatus @default(PENDING)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user      User?     @relation(fields: [userId], references: [id])
  property   Property @relation(fields: [propertyId], references: [id])

  @@map("inquiries")
}

model PropertyView {
  id          String   @id @default(cuid())
  userId      String?
  propertyId  String
  viewedAt    DateTime @default(now())

  // Relations
  user      User?     @relation(fields: [userId], references: [id])
  property   Property @relation(fields: [propertyId], references: [id])

  @@unique([userId, propertyId])
  @@map("property_views")
}

model UserRating {
  id            String   @id @default(cuid())

  // Who gave the rating
  fromUserId    String
  fromUser      User     @relation("RatingsGiven", fields: [fromUserId], references: [id], onDelete: Cascade)

  // Who received the rating
  toUserId      String
  toUser        User     @relation("RatingsReceived", fields: [toUserId], references: [id], onDelete: Cascade)

  // Rating details
  rating        Int      @db.SmallInt // 1-5 stars
  review        String?  // Optional review text
  ratingType    RatingType // OWNER or TENANT

  // Optional: Link to booking
  bookingId     String?
  booking       Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  // Timestamps
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Unique constraint: one rating per user pair per booking
  @@unique([fromUserId, toUserId, bookingId])
  @@index([toUserId])
  @@index([fromUserId])

  @@map("user_ratings")
}

enum RatingType {
  OWNER
  TENANT
}

enum InquiryStatus {
  PENDING
  RESPONDED
  CLOSED
}
